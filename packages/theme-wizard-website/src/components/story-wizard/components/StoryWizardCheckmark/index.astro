---
import checkIcon from '@tabler/icons/outline/check.svg?raw';

interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<span class:list={['wizard-checkmark', className]} aria-label="Voltooid" hidden {...rest} set:html={checkIcon} />

<style>
  .wizard-checkmark {
    align-items: center;
    block-size: var(--basis-size-icon-md);
    color: var(--basis-color-positive-color-default);
    display: inline-flex;
    flex-shrink: 0;
    inline-size: var(--basis-size-icon-md);
    justify-content: center;
    padding-block: 0.125rem;
    padding-inline: 0.125rem;
  }

  /* stylelint-disable-next-line selector-pseudo-class-no-unknown */
  .wizard-checkmark :global(svg) {
    block-size: 100%;
    inline-size: 100%;
  }

  .wizard-checkmark[hidden] {
    display: none;
  }
</style>
