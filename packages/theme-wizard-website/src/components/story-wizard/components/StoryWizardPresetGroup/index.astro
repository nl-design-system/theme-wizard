---
import type { StoryWizardPresetGroup } from '@/lib/types';

interface Props {
  group: StoryWizardPresetGroup;
}

const { group } = Astro.props;
---

<section class="wizard-token-preset" data-preset-group data-group-label={group.name}>
  <h3 class="nl-heading nl-heading--level-4 wizard-token-preset__title">{group.name}</h3>

  {group.description && <p class="nl-paragraph wizard-token-preset__description">{group.description}</p>}

  <div class="wizard-token-preset__layout">
    <div class="wizard-token-preset__options">
      <wizard-token-preset
        class="wizard-token-preset__input"
        group-label={group.name}
        options={JSON.stringify(group.options)}></wizard-token-preset>
    </div>
  </div>
</section>
