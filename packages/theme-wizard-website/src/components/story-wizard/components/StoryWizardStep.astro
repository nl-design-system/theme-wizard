---
import type { StoryWizardStep as StoryWizardStepViewModel } from '@/lib/types';
import StoryWizardEditableTokenGroup from './StoryWizardEditableTokenGroup/index.astro';
import StoryWizardPresetGroup from './StoryWizardPresetGroup/index.astro';

interface Props {
  step: StoryWizardStepViewModel;
  stepIndex: number;
  totalSteps: number;
}

const { step } = Astro.props;
---

<section
  id={step.id}
  class="wizard-story-section"
  aria-label={step.title}
  data-step-kind={step.type === 'advanced' ? 'advanced' : 'safe'}
  data-step-label={step.title}
>
  <div class="wizard-story-section__layout">
    <aside class="wizard-story-section__settings-panel" aria-label={`${step.title}`}>
      <div class="wizard-story-section__intro">
        <h2 class="nl-heading nl-heading--level-3 wizard-story-section__step-title">{step.title}</h2>
        {step.intro && <p class="nl-paragraph wizard-story-section__step-help">{step.intro}</p>}
      </div>

      {
        step.groups.map((group) =>
          group.type === 'preset' ? (
            <StoryWizardPresetGroup group={group} />
          ) : (
            <StoryWizardEditableTokenGroup group={group} />
          ),
        )
      }
    </aside>

    <div class="wizard-story-section__preview-column">
      {
        step.previewStories.length > 0 && (
          <section class="wizard-story-preview-panel" aria-label={`${step.title} previews`}>
            <div class="wizard-story-section__variants">
              {step.previewStories.map((previewStory) => (
                <div class="wizard-story-section__variant">
                  <p class="nl-paragraph wizard-story-section__variant-label">{previewStory.name}</p>
                  <wizard-story-preview>
                    <wizard-reset-theme>
                      <wizard-preview-theme>
                        <div data-story-container={previewStory.id} />
                      </wizard-preview-theme>
                    </wizard-reset-theme>
                  </wizard-story-preview>
                </div>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </div>
</section>
