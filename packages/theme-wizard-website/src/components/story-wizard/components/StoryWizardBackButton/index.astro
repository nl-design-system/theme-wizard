---
import chevronLeftIcon from '@tabler/icons/outline/chevron-left.svg?raw';

interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a href={href} class="nl-link wizard-back-overview-btn" role="button">
  <span class="wizard-back-overview-btn__icon" aria-hidden="true" set:html={chevronLeftIcon} />
  <span class="wizard-back-overview-btn__label">Terug naar overzicht</span>
</a>
