---
import type { StoryWizardViewModel } from '@/lib/story-wizard';
import StoryWizardStep from './components/StoryWizardStep.astro';
import StoryWizardStepper from './components/StoryWizardStepper.astro';

interface Props {
  wizard: StoryWizardViewModel;
}

const { wizard } = Astro.props;
---

<div slot="page-content" class="wizard-page-content">
  <section data-story-wizard-root>
    <div id="story-wizard" data-story-ids={JSON.stringify(wizard.storyIds)} data-component-id={wizard.componentId} hidden>
    </div>

    {wizard.steps.map((step) => <StoryWizardStep step={step} />)}

    <StoryWizardStepper />
  </section>
</div>
