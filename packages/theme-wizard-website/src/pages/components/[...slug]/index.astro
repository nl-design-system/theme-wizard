---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@nl-design-system-candidate/button-css/button.css';
import { components } from '@/lib/components';
import { getStories } from '../../../../../theme-wizard-app/src/utils/csf-utils';
import { tokensToStyle } from '../../../../../theme-wizard-app/src/lib/Theme/lib';

import './index.css';

export function getStaticPaths() {
  return Object.keys(components).map(slug => ({
    params: { slug }
  }))
}

const componentList = await Promise.all(Object.entries(components).map(async ([slug, {title}]) => {
  return {
    slug,
    title
  }
}))

type PresetOptionObject = {
  name: string;
  description?: string;
  tokens: unknown;
}

type PresetObject = {
  name: string;
  description?: string;
  options: PresetOptionObject[];
  question?: string;
  thumbnail?: boolean;
}

type StoryObject = {
  name?: string;
  parameters?: {
    presets?: PresetObject[];
    [key: PropertyKey]: unknown;
  };
  [key: PropertyKey]: unknown;
};

const slug = Astro.params.slug as keyof typeof components
const componentModulePromiseFn = components[slug].stories
const componentModule = await componentModulePromiseFn()
const { default: meta, ...storyExports } = componentModule
const allStories = getStories(storyExports as unknown as Record<PropertyKey, StoryObject>, meta)
const presetStories = allStories.filter(([_, story]) => story.parameters?.presets)
const previewStories = slug === 'button'
  ? (() => {
      const story = allStories.find(([_, candidate]) => candidate.name === 'Wizard Preview')
      return story ? [story] : []
    })()
  : (() => {
      const interactionStory = presetStories.find(([_, story]) => story.name === 'Interactiestijl')
      return interactionStory ? [interactionStory] : presetStories.slice(0, 1)
    })()
const storyIds = Array.from(new Set([...presetStories.map(([id]) => id), ...previewStories.map(([id]) => id)]))

---

<BaseLayout title={`${slug} - Theme Wizard`}>
  <theme-wizard-app>
    <wizard-layout>
      <wizard-page-nav slot="page-nav"></wizard-page-nav>

      <!-- TODO: implement proper sidenav https://github.com/nl-design-system/theme-wizard/issues/532 -->
      <nav slot="sidebar">
        {componentList.map(({slug: componentSlug, title}) => (
          <wizard-sidebar-link href={`/components/${componentSlug}`} current={componentSlug === slug ? 'page' : undefined}>{title}</wizard-sidebar-link>
        ))}
      </nav>
      <main slot="main" class="wizard-main">
        <!-- TODO: make proper breadcrumb https://github.com/nl-design-system/theme-wizard/issues/531 -->
        <nav>
          <a href="/">Wizard</a> /
          <a href="/components">componenten</a> /
          <span>{slug}</span>
        </nav>

        <h1>{slug}</h1>
        <p class="wizard-selected-values" aria-live="polite" hidden>Nog geen preset gekozen.</p>
        <details class="wizard-step-selections" hidden>
          <summary class="wizard-step-selections__summary">Gekozen presets per stap (0/0)</summary>
          <div class="wizard-step-selections__list"></div>
        </details>
        <div slot="page-content" class="wizard-page-content">
          <div id="story-container" data-story-ids={JSON.stringify(storyIds)} data-component-id={slug} hidden></div>

          {presetStories.map(([id, story]) => (
            <section id={id} class="wizard-story-section" aria-labelledby={`${id}-title`} data-step-label={story.name ?? id}>
              <header class="wizard-story-section__header">
                <p class="wizard-story-section__intro">Kies een preset om direct te zien hoe dit component zich in de wizard gedraagt.</p>
              </header>
              <div class="wizard-story-section__variants" aria-label="Buttonvarianten">
                {previewStories.map(([previewId, previewStory]) => (
                  <div class="wizard-story-section__variant">
                    <p class="wizard-story-section__variant-label">{previewStory.name ?? previewId}</p>
                    <wizard-story-preview>
                      <wizard-reset-theme>
                        <wizard-preview-theme>
                          <div data-story-container={previewId}></div>
                        </wizard-preview-theme>
                      </wizard-reset-theme>
                    </wizard-story-preview>
                  </div>
                ))}
              </div>
              {
                story.parameters?.presets?.map((preset, presetIndex) => (
                  <section class="wizard-token-preset" data-preset-group data-group-label={preset.question ?? preset.name}>
                    <h2 class="wizard-token-preset__title">{preset.question ?? preset.name}</h2>
                    {preset.description && <p class="wizard-token-preset__description">{preset.description}</p>}
                    <div class="wizard-token-preset__layout">
                      <div class="wizard-token-preset__options">
                        {preset.options.map((option, optionIndex) => {
                          const inputId = `${id}-preset-${presetIndex}-option-${optionIndex}`
                          const inputName = `${id}-preset-${presetIndex}`

                          return (
                            <div class="wizard-token-preset__option">
                              <input
                                class="wizard-token-preset__input"
                                id={inputId}
                                name={inputName}
                                type="radio"
                                value={String(optionIndex)}
                                data-option-label={option.name}
                                data-tokens={JSON.stringify(option.tokens)}
                              />
                              <label class="wizard-token-preset__label" for={inputId}>
                                <div class="wizard-token-preset__option-inner">
                                  {preset.thumbnail !== false && (
                                    <div class="wizard-token-preset__option-thumbnail">
                                      <wizard-reset-theme>
                                        <wizard-preview-theme style={tokensToStyle(option.tokens as any)}>
                                          <div role="img">
                                            <div data-story-container={id} aria-hidden="true" inert></div>
                                          </div>
                                        </wizard-preview-theme>
                                      </wizard-reset-theme>
                                    </div>
                                  )}
                                  <div class="wizard-token-preset__option-text">
                                    <p class="wizard-token-preset__option-title">{option.name}</p>
                                    {option.description && <p class="wizard-token-preset__option-description">{option.description}</p>}
                                  </div>
                                </div>
                              </label>
                            </div>
                          )
                        }
                        )}
                      </div>
                    </div>
                  </section>
                ))
              }
            </section>
          ))}

          <nav class="wizard-preset-stepper" aria-label="Navigeer tussen keuzes" hidden>
            <span class="wizard-preset-step-indicator" aria-live="polite"></span>
            <div class="wizard-preset-stepper__actions">
              <button class="wizard-preset-prev nl-button nl-button--subtle" type="button">Vorige</button>
              <button class="wizard-preset-next nl-button nl-button--primary nl-button--disabled" type="button" disabled>Volgende</button>
            </div>
          </nav>
        </div>
        <a href={`/components/${slug}/tokens`}>Ga naar alle component tokens</a>
      </main>
     </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<script>
  import { initStories } from '@/components/render-stories';
  import type { components } from '@/lib/components';

  type WizardTokenPresetInput = HTMLInputElement;
  type DesignTokenLeaf = { path: string; value: string };

  const container = document.getElementById('story-container');
  const storyIds = JSON.parse(container!.dataset.storyIds || '[]');
  // Assertion here is type-safe because that's taken care of by Astro in the top of this file
  const componentId = container?.dataset.componentId! as keyof typeof components

  initStories(componentId, storyIds);

  const allSections = Array.from(document.querySelectorAll<HTMLElement>('.wizard-story-section'));
  const total = allSections.length;
  let currentStep = 0;

  const stepper = document.querySelector<HTMLElement>('.wizard-preset-stepper');
  const prevBtn = document.querySelector<HTMLButtonElement>('.wizard-preset-prev');
  const nextBtn = document.querySelector<HTMLButtonElement>('.wizard-preset-next');
  const indicator = document.querySelector<HTMLElement>('.wizard-preset-step-indicator');
  const selectedValues = document.querySelector<HTMLElement>('.wizard-selected-values');
  const stepSelectionsSummary = document.querySelector<HTMLElement>('.wizard-step-selections__summary');
  const stepSelectionsList = document.querySelector<HTMLElement>('.wizard-step-selections__list');
  const stepSelections = document.querySelector<HTMLElement>('.wizard-step-selections');
  document.querySelectorAll('.wizard-token-preset__layout').forEach(layout => {
    layout.querySelectorAll<WizardTokenPresetInput>('.wizard-token-preset__input').forEach(option => {
      option.addEventListener('change', () => {
        writeStoredState();
        updateStepSelections();
        updateSelectedValues(currentStep);
        updateNextButtonState(currentStep);
      });
    });
  });

  const storageKey = `theme-wizard:${componentId}:preset-state`;

  function readStoredState() {
    try {
      const raw = globalThis.localStorage?.getItem(storageKey);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null;
    }
  }

  function writeStoredState() {
    try {
      const state = {
        currentStep,
        sections: allSections.map(section =>
          Array.from(section.querySelectorAll<HTMLElement>('[data-preset-group]')).map(group =>
            Array.from(group.querySelectorAll<WizardTokenPresetInput>('.wizard-token-preset__input')).findIndex(option => option.checked)
          )
        ),
      };

      globalThis.localStorage?.setItem(storageKey, JSON.stringify(state));
    } catch {
      // Progressive enhancement: ignore storage failures and keep the wizard usable.
    }
  }

  function restoreStoredState() {
    const storedState = readStoredState();
    if (!storedState) return 0;

    storedState.sections?.forEach((groupSelections: number[], sectionIndex: number) => {
      const section = allSections[sectionIndex];
      if (!section) return;

      Array.from(section.querySelectorAll<HTMLElement>('[data-preset-group]')).forEach((group, groupIndex) => {
        const selectedIndex = groupSelections?.[groupIndex];
        if (typeof selectedIndex !== 'number' || selectedIndex < 0) return;

        Array.from(group.querySelectorAll<WizardTokenPresetInput>('.wizard-token-preset__input')).forEach((option, optionIndex) => {
          option.checked = optionIndex === selectedIndex;
        });
      });
    });

    if (typeof storedState.currentStep === 'number' && storedState.currentStep >= 0 && storedState.currentStep < total) {
      return storedState.currentStep;
    }

    return 0;
  }

  function flattenDesignTokens(tokens: unknown, path: string[] = []): DesignTokenLeaf[] {
    if (!tokens || typeof tokens !== 'object') return [];

    if ('$value' in (tokens as Record<string, unknown>)) {
      return [{
        path: path.join('.'),
        value: JSON.stringify((tokens as { $value: unknown }).$value),
      }];
    }

    return Object.entries(tokens as Record<string, unknown>).flatMap(([key, value]) =>
      flattenDesignTokens(value, [...path, key])
    );
  }

  function getSelectedOption(group: HTMLElement) {
    return Array.from(group.querySelectorAll<WizardTokenPresetInput>('.wizard-token-preset__input'))
      .find(option => option.checked);
  }

  function sectionHasRequiredSelections(section: HTMLElement) {
    const groups = Array.from(section.querySelectorAll<HTMLElement>('[data-preset-group]'));
    return groups.every(group =>
      Array.from(group.querySelectorAll<WizardTokenPresetInput>('.wizard-token-preset__input')).some(option => option.checked)
    );
  }

  function updateNextButtonState(index: number) {
    if (!nextBtn) return;
    const isComplete = sectionHasRequiredSelections(allSections[index]);
    const isLastStep = index === total - 1;
    nextBtn.disabled = !isComplete;
    nextBtn.classList.toggle('nl-button--disabled', !isComplete);
    nextBtn.textContent = isLastStep ? 'Afronden' : 'Volgende';
  }

  function updateSelectedValues(index: number) {
    if (!selectedValues) return;
    const labels = getSelectionLabels(allSections[index]);
    selectedValues.textContent = labels.length > 0 ? labels.join(' • ') : 'Nog geen preset gekozen.';
  }

  function getSelectionLabels(section: HTMLElement) {
    return Array.from(section.querySelectorAll<HTMLElement>('[data-preset-group]')).flatMap(group => {
      const label = group.dataset.groupLabel?.trim();
      const value = getSelectedOption(group)?.dataset.optionLabel?.trim();

      if (!label || !value) return [];
      return [`${label}: ${value}`];
    });
  }

  function updateStepSelections() {
    if (!stepSelectionsList) return;
    stepSelectionsList.replaceChildren();

    let completedSteps = 0;

    allSections.forEach((section, index) => {
      const wrapper = document.createElement('section');
      wrapper.className = 'wizard-step-selection';

      const header = document.createElement('div');
      header.className = 'wizard-step-selection__header';

      const title = document.createElement('p');
      title.className = 'wizard-step-selection__title';
      title.textContent = `Stap ${index + 1}: ${section.dataset.stepLabel || `Stap ${index + 1}`}`;

      const selections = getSelectionLabels(section);
      const selectedGroups = Array.from(section.querySelectorAll<HTMLElement>('[data-preset-group]')).flatMap(group => {
        const option = getSelectedOption(group);
        if (!option) return [];

        let tokens: unknown = null;
        try {
          tokens = JSON.parse(option.getAttribute('value') || '{}');
        } catch {
          tokens = {};
        }

        return [{
          label: group.dataset.groupLabel?.trim() || '',
          optionLabel: option.dataset.optionLabel?.trim() || '',
          tokens: flattenDesignTokens(tokens),
        }];
      });

      header.appendChild(title);

      wrapper.appendChild(header);

      if (selectedGroups.length > 0) {
        if (selections.length > 0) completedSteps += 1;
        selectedGroups.forEach(group => {
          const groupBlock = document.createElement('div');
          groupBlock.className = 'wizard-step-selection__group';

          const groupTitle = document.createElement('p');
          groupTitle.className = 'wizard-step-selection__group-title';
          groupTitle.textContent = group.optionLabel;
          groupBlock.appendChild(groupTitle);

          const tokenList = document.createElement('ul');
          tokenList.className = 'wizard-step-selection__tokens';

          group.tokens.forEach(token => {
            const item = document.createElement('li');
            item.className = 'wizard-step-selection__token';

            const tokenText = document.createElement('code');
            tokenText.className = 'wizard-step-selection__token-text';
            tokenText.textContent = `${token.path}: ${token.value}`;

            item.appendChild(tokenText);
            tokenList.appendChild(item);
          });

          groupBlock.appendChild(tokenList);
          wrapper.appendChild(groupBlock);
        });
      } else {
        const summary = document.createElement('p');
        summary.className = 'wizard-step-selection__summary';
        summary.textContent = 'Nog geen preset gekozen.';
        wrapper.appendChild(summary);
      }

      stepSelectionsList.appendChild(wrapper);
    });

    if (stepSelectionsSummary) {
      stepSelectionsSummary.textContent = `Gekozen presets per stap (${completedSteps}/${total})`;
    }
  }

  function showStep(index: number) {
    allSections.forEach((section, i) => { section.hidden = i !== index; });
    currentStep = index;
    if (indicator) indicator.textContent = `Stap ${index + 1} van ${total}`;
    if (prevBtn) prevBtn.disabled = index === 0;
    prevBtn?.classList.toggle('nl-button--disabled', index === 0);
    updateStepSelections();
    updateSelectedValues(index);
    updateNextButtonState(index);
    writeStoredState();
  }

  prevBtn?.addEventListener('click', () => {
    if (currentStep > 0) showStep(currentStep - 1);
  });
  nextBtn?.addEventListener('click', () => {
    if (currentStep < total - 1) showStep(currentStep + 1);
  });

  if (total === 0) {
    stepper?.setAttribute('hidden', '');
  } else {
    selectedValues?.removeAttribute('hidden');
    stepSelections?.removeAttribute('hidden');
    stepper?.removeAttribute('hidden');
    showStep(restoreStoredState());
  }
</script>
