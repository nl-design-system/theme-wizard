---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { components } from '@/lib/components';
import { getStories } from '../../../../../theme-wizard-app/src/utils/csf-utils';
import { tokensToStyle } from '../../../../../theme-wizard-app/src/lib/Theme/lib';

import './index.css';

export function getStaticPaths() {
  return Object.keys(components).map(slug => ({
    params: { slug }
  }))
}

const componentList = await Promise.all(Object.entries(components).map(async ([slug, {title}]) => {
  return {
    slug,
    title
  }
}))

type PresetOptionObject = {
  name: string;
  tokens: unknown;
}

type PresetObject = {
  name: string;
  description?: string;
  options: PresetOptionObject[]
}

type StoryObject = {
  name?: string;
  parameters?: {
    presets?: PresetObject[];
    [key: PropertyKey]: unknown;
  };
  [key: PropertyKey]: unknown;
};

const slug = Astro.params.slug as keyof typeof components
const componentModulePromiseFn = components[slug].stories
const componentModule = await componentModulePromiseFn()
const { default: meta, ...storyExports } = componentModule
const presetStories = getStories(storyExports as unknown as Record<PropertyKey, StoryObject>, meta).filter(([_, story]) => story.parameters?.presets)
---

<BaseLayout title={`${slug} - Theme Wizard`}>
  <theme-wizard-app>
    <wizard-layout>
      <wizard-page-nav slot="page-nav"></wizard-page-nav>

      <!-- TODO: implement proper sidenav https://github.com/nl-design-system/theme-wizard/issues/532 -->
      <nav slot="sidebar">
        {componentList.map(({slug: componentSlug, title}) => (
          <wizard-sidebar-link href={`/components/${componentSlug}`} current={componentSlug === slug ? 'page' : undefined}>{title}</wizard-sidebar-link>
        ))}
      </nav>
      <main slot="main" class="wizard-main">
        <!-- TODO: make proper breadcrumb https://github.com/nl-design-system/theme-wizard/issues/531 -->
        <nav>
          <a href="/">Wizard</a> /
          <a href="/components">componenten</a> /
          <span>{slug}</span>
        </nav>

        <h1>{slug}</h1>
        <div slot="page-content" class="wizard-page-content">
          <div id="story-container" data-story-ids={JSON.stringify(presetStories.map(([id])=> id))} data-component-id={slug} hidden></div>

          {presetStories.map(([id, story]) => (
            <section id={id} class="wizard-story-section">
              <clippy-heading level="2">{story.name}</clippy-heading>
              <wizard-story-preview>
                {/* theme-preview makes sure the CSS generated by theme-wizard config gets applied after reset */}
                <wizard-reset-theme>
                  <wizard-preview-theme>
                    <div data-story-container={id}></div>
                  </wizard-preview-theme>
                </wizard-reset-theme>
              </wizard-story-preview>
              {
                story.parameters?.presets?.map((preset) => (
                  <div class="wizard-token-preset">
                  <h2 class="wizard-token-preset__title">{preset.name}</h2>
                  <p class="wizard-token-preset__description">{preset.description}</p>
                    {
                      preset.options.map(option => 
                        <wizard-token-preset value={JSON.stringify(option.tokens)}>
                          <div>
                            <wizard-story-preview>
                            <wizard-reset-theme>
                              <wizard-preview-theme style={tokensToStyle(option.tokens as any)}>
                                <div role="img">
                                  <div data-story-container={id} aria-hidden="true" inert></div>
                                </div>
                              </wizard-preview-theme>
                            </wizard-reset-theme>
                            </wizard-story-preview>
                            <p class="wizard-token-preset__option-title">{option.name}</p>
                          </div>
                        </wizard-token-preset>
                    )}
                  </div>
                  ))
              }
            </section>
          ))}
        </div> 
        <a href={`/components/${slug}/tokens`}>Ga naar alle component tokens</a>
      </main>
     </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<script>
  import { initStories } from '@/components/render-stories';
  import type { components } from '@/lib/components';

  const container = document.getElementById('story-container');
  const storyIds = JSON.parse(container!.dataset.storyIds || '[]');
  // Assertion here is type-safe because that's taken care of by Astro in the top of this file
  const componentId = container?.dataset.componentId! as keyof typeof components

  initStories(componentId, storyIds);

</script>