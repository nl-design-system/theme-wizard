---
import WizardLayout from '../../layouts/WizardLayout.astro';
---

<WizardLayout title="Configureer je thema">
  <header slot="header">
    <wizard-stack size="md">
      <clippy-heading level="2">Maak de eerste keuzes voor je thema</clippy-heading>
      <p class="nl-paragraph nl-paragraph--lead">Voor een optimaal werkend thema maak je eerst keuzes op hoog niveau.</p>
    </wizard-stack>
  </header>
  <nav aria-labelledby="wizard-nav-title">
    <wizard-stack size="lg">
      <clippy-heading level="2" id="wizard-nav-title">Maak stapsgewijs keuzes</clippy-heading>
      <wizard-step-form-task-navigation-list></wizard-step-form-task-navigation-list>
    </wizard-stack>
  </nav>
</WizardLayout>
