---
import '@nl-design-system-community/clippy-components/clippy-reset-theme';
import '@nl-design-system-community/clippy-components/clippy-story-preview';
import { withRelatedProject } from '@vercel/related-projects';
import BaseLayout from '../layouts/BaseLayout.astro';
import { TEMPLATES_JSON } from '@nl-design-system-community/theme-wizard-templates';

export const prerender = false; // enable SSR

const scraperUrl = withRelatedProject({
  projectName: 'theme-wizard-server',
  // Fallback API host
  defaultHost: process.env.API_HOST || '',
});

const templates = JSON.parse(TEMPLATES_JSON)
let currentTemplate = Astro.url.searchParams.get('templatePath')
if (!currentTemplate) {
  const group = templates?.at(1);
  const option = group?.pages?.at(1);
  currentTemplate = option?.value ?? '';
}
---

<style>
  /**
   * We need the browser-preview to adjust its height with taking the page-nav, paddings, and picker controls in mind.
   * This also needs to be sticky.
   * So we need a bit of CSS magic and variables to achieve the desired effect.
   */
  .wizard-main {
    --wizard-main-block-start-correction: calc(
      /* Layout header */
      var(--wizard-page-nav-block-size, 4rem) +
      /* layout-body-padding-block top */
      var(
        --wizard-layout-body-padding-block,
        var(--basis-space-block-xl)
      )
    );

    align-self: flex-start;
    display: grid;
    grid-template-rows: var(--wizard-layout-body-template-rows, none);
    inset-block-start: var(--wizard-main-block-start-correction);
    padding-block-end: var(--basis-space-block-lg);
    position: sticky;
    row-gap: var(--basis-space-row-lg);
  }

  .wizard-preview-picker {
    justify-self: end;
  }

  /**
   * 1. `browser-window` applies a `transition: all`. We dont want that (esp. with screne resizing).
   * 2. Calculate the preview height. We could simplify this by setting the size on the
   *    `wizard-main` class, but instead we need to place the sizing on the preview
   *    because the preview is also resizable.
   */
  .wizard-preview {
    --wizard-scroll-container-max-size: 100%;

    background-color: Canvas;
    display: flex;
    flex-direction: column;
    max-inline-size: 100%;
    transition: none; /* [1] */

    @media (height >= 40rem) {
      block-size: calc(
        /* Dynamic viewport */
        100dvb -
        /* Header + layout padding */
        var(--wizard-main-block-start-correction) -
        /* Preview picker size */
        var(--basis-size-md) -
        /* space between picker and preview */
        var(--basis-space-row-lg) -
        /* layout-body-padding-block bottom */
        var(
          --wizard-layout-body-padding-block,
          var(--basis-space-block-xl)
        )
      ); /* [2] */
    }

    &::part(content) {
      overflow: auto;
    }
  }
</style>

<BaseLayout title="Huisstijl bewerken - Theme Wizard">
  <theme-wizard-app>
    <wizard-layout>
      <wizard-page-nav slot="page-nav"></wizard-page-nav>

      <wizard-tokens-form slot="sidebar"></wizard-tokens-form>

      <div slot="main" class="wizard-main">
        <wizard-preview-picker class="wizard-preview-picker" templates={TEMPLATES_JSON} value={currentTemplate}></wizard-preview-picker>
        <browser-window shadow url="https://gemeentevoorbeeld.nl" class="wizard-preview">
          <wizard-scroll-container>
            <clippy-reset-theme>
              <wizard-preview-theme>
                <wizard-preview url={currentTemplate} scraperUrl={scraperUrl}></wizard-preview>
              </wizard-preview-theme>
            </clippy-reset-theme>
          </wizard-scroll-container>
        </browser-window>
      </div>
     </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<script>
  import '@profpowell/browser-window';
</script>
