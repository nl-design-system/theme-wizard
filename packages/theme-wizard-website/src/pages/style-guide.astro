---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Style Guide - Theme Wizard" description="Preview and analyze website themes">
  <theme-wizard-app>
    <wizard-layout>
      <div slot="main">
        <h1>Stijlgids</h1>
        <div class="wrap">
          <wizard-anchor-nav items={JSON.stringify([{title: "Typografie", id: "typography"}, {title: "Kleuren", id: "colors"}, {title: "Witruimte", id: "spacing"}, {title: "Componenten", id: "components"}])}></wizard-anchor-nav>
          <div>
            <wizard-style-guide-typography id="typography"></wizard-style-guide-typography>
            <wizard-style-guide-colors id="colors"></wizard-style-guide-colors>
            <wizard-style-guide-spacing id="spacing"></wizard-style-guide-spacing>
            <wizard-style-guide-components id="components"></wizard-style-guide-components>
          </div>
        </div>
      </div>
    </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<style>
  .wrap {
    align-items: start;
    column-gap: var(--basis-space-column-3xl);
    display: grid;
    grid-template-columns: 1fr 14rem;
    position: relative;
  }

  wizard-anchor-nav {
    order: 2;
    position: sticky;
    top: 6rem;
    right: 0;
    bottom: 0;
    border-left: 1px solid var(--basis-color-default-border-subtle);
    padding-inline-start: var(--basis-space-column-3xl);
    padding-block: var(--basis-space-block-xl);
    max-block-size: 85vh;
    overflow: auto;
    scrollbar-width: thin;
    scrollbar-color:  var(--basis-color-action-1-color-default) transparent;
  }
</style>