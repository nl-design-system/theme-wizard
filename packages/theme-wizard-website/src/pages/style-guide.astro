---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WithPageNav from '@/components/WithPageNav.astro';
import '@nl-design-system-community/clippy-components/clippy-story-preview';

const SECTION_IDS = {
  typography: 'typography',
  colors: 'colors',
  spacing: 'spacing',
  components: 'components'
}
---

<BaseLayout title="Stijlgids - Theme Wizard">
  <theme-wizard-app>
    <wizard-layout>
      <wizard-page-nav slot="page-nav"></wizard-page-nav>

      <div slot="main" class="wizard-main">
        <wizard-container>
          <clippy-story-preview size="lg">
            <wizard-stack size="4xl">
              <clippy-heading level="1">Stijlgids</clippy-heading>
              <WithPageNav>
                <div slot="page-nav">
                  <wizard-anchor-nav items={JSON.stringify([{title: "Typografie", id: SECTION_IDS.typography}, {title: "Kleuren", id: SECTION_IDS.colors}, {title: "Witruimte", id: SECTION_IDS.spacing}, {title: "Componenten", id: SECTION_IDS.components}])}></wizard-anchor-nav>
                </div>
                <wizard-stack size="3xl" slot="page-content">
                  <section>
                    <wizard-stack size="2xl">
                      <clippy-heading level="2" id={SECTION_IDS.typography}>Typografie</clippy-heading>
                      <wizard-style-guide-typography></wizard-style-guide-typography>
                    </wizard-stack>
                  </section>
                  <section>
                    <wizard-stack size="2xl">
                      <h2 id={SECTION_IDS.colors}>Kleuren</h2>
                      <wizard-style-guide-colors></wizard-style-guide-colors>
                    </wizard-stack>
                  </section>
                  <section>
                    <wizard-stack size="2xl">
                      <h2 id={SECTION_IDS.spacing}>Witruimte</h2>
                      <wizard-style-guide-spacing></wizard-style-guide-spacing>
                    </wizard-stack>
                  </section>
                  <section>
                    <wizard-stack size="2xl">
                      <h2 id={SECTION_IDS.components}>Componenten</h2>
                      <wizard-style-guide-components></wizard-style-guide-components>
                    </wizard-stack>
                  </section>
                </wizard-stack>
              </WithPageNav>
            </wizard-stack>
          </clippy-story-preview>
        </wizard-container>
      </div>
    </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<style>
  .wizard-main {
    padding-block-end: var(--basis-space-block-6xl);
    padding-block-start: var(--basis-space-block-4xl);
  }
</style>