---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Style Guide - Theme Wizard" description="Preview and analyze website themes">
  <theme-wizard-app>
    <wizard-layout>
      <div slot="main">
        <h1>Stijlgids</h1>
        <div class="wrap">
          <wizard-anchor-nav items={JSON.stringify([{title: "Typografie", id: "typography"}, {title: "Kleuren", id: "colors"}, {title: "Witruimte", id: "spacing"}, {title: "Componenten", id: "components"}])}></wizard-anchor-nav>
          <wizard-style-guide></wizard-style-guide>
        </div>
      </div>
    </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<script>
  document.querySelector('wizard-anchor-nav')?.addEventListener('click', (event) => {
    const target = event.target as HTMLElement
    console.log(event.target, event.currentTarget)
    if (target?.tagName !== 'WIZARD_ANCHOR_NAV') return
    const styleGuide = document.querySelector('wizard-style-guide')
    const elementId = target.getAttribute('href')?.slice(1)
    if (!elementId) return
    const scrollTarget = styleGuide?.shadowRoot?.getElementById(elementId)
    scrollTarget?.scrollIntoView()
  })
</script>

<style>
  .wrap {
    align-items: start;
    column-gap: var(--basis-space-column-3xl);
    display: grid;
    grid-template-columns: 1fr 18rem;
    position: relative;
  }

  wizard-anchor-nav {
    order: 2;
    position: sticky;
    top: 6rem;
    right: 0;
    bottom: 0;
    border-left: 1px solid var(--basis-color-default-border-subtle);
    padding-inline-start: var(--basis-space-column-3xl);
    padding-block: var(--basis-space-block-xl);
    max-block-size: 85vh;
    overflow: auto;
    scrollbar-width: thin;
    scrollbar-color:  var(--basis-color-action-1-color-default) transparent;
  }
</style>