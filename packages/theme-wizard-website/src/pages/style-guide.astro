---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WithPageNav from '@/components/WithPageNav.astro';
---

<BaseLayout title="Style Guide - Theme Wizard" description="Preview and analyze website themes">
  <theme-wizard-app>
    <wizard-layout>
      <div slot="main">
        <h1>Stijlgids</h1>
        <WithPageNav>
          <div slot="page-nav">
            <wizard-anchor-nav items={JSON.stringify([{title: "Typografie", id: "typography"}, {title: "Kleuren", id: "colors"}, {title: "Witruimte", id: "spacing"}, {title: "Componenten", id: "components"}])}></wizard-anchor-nav>
          </div>
          <div class="wizard-style-guides" slot="page-content">
            <section>
              <h2 id="typography">Typografie</h2>
              <wizard-style-guide-typography></wizard-style-guide-typography>
            </section>
            <section>
              <h2 id="colors">Kleuren</h2>
              <wizard-style-guide-colors></wizard-style-guide-colors>
            </section>
            <section>
              <h2 id="spacing">Witruimte</h2>
              <wizard-style-guide-spacing></wizard-style-guide-spacing>
            </section>
            <section>
              <h2 id="components">Componenten</h2>
              <wizard-style-guide-components></wizard-style-guide-components>
            </section>
          </div>
        </WithPageNav>
      </div>
    </wizard-layout>
  </theme-wizard-app>
</BaseLayout>

<style>
  .wizard-style-guides {
    display: grid;
    row-gap: var(--basis-space-row-3xl);
  }
</style>