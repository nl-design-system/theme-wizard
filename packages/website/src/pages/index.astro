---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Theme Wizard - Lit POC" description="Preview and analyze website themes">
  <lit-theme-app>
    <lit-theme-sidebar slot="sidebar"></lit-theme-sidebar>
    <lit-theme-preview slot="preview" id="theme-preview"></lit-theme-preview>
  </lit-theme-app>
</BaseLayout>

<style>
  body {
    font-family: system-ui, sans-serif;
  }
</style>
