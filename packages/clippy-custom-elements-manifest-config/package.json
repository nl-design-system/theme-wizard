{
  "name": "@nl-design-system-community/clippy-custom-elements-manifest-config",
  "version": "1.0.0",
  "author": "Community for NL Design System",
  "description": "Custom elements manifest config for Clippy Components",
  "license": "EUPL-1.2",
  "keywords": [
    "expertteam-digitale-toegankelijkheid",
    "nl-design-system"
  ],
  "private": true,
  "type": "module",
  "module": "./dist/index.js",
  "exports": {
    "./*": {
      "import": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:nl-design-system/theme-wizard.git",
    "directory": "packages/clippy-custom-elements-manifest-config"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "build": "pnpm type-check && pnpm clean && vite build",
    "clean": "rimraf dist/",
    "lint": "pnpm run --sequential '/^lint:.+$/'",
    "lint:js": "eslint",
    "lint-fix:js": "eslint --fix",
    "lint-build": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "glob": "13.0.6",
    "rimraf": "6.1.3",
    "vite": "8.0.10",
    "vite-plugin-dts": "5.0.0"
  },
  "dependencies": {
    "@wc-toolkit/type-parser": "1.2.0",
    "command-line-args": "6.0.2",
    "comment-parser": "1.4.6"
  }
}
