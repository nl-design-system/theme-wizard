{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "paths": {
      "@lib/*": ["../clippy-components/src/lib/*"],
      "@nl-design-system-community/clippy-components/*": ["../clippy-components/src/*"],
      "@src/*": ["../clippy-components/src/*"]
    },
    "types": ["vite/client"],
    "importHelpers": false,
    "useDefineForClassFields": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*"]
}
